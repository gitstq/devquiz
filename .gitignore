# DevQuiz .gitignore

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Python (for local dev if any)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
.venv
env/
venv/

# Node (if using local build tools)
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.bundle.js

# Logs
*.log
npm-debug.log*

# Temporary files
*.tmp
*.temp
.cache/
